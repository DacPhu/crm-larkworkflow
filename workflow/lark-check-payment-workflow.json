{
  "name": "Lark CRM - Check Payment Status",
  "nodes": [
    {
      "id": "cp-01-webhook",
      "name": "Webhook - Check Payment",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "GET",
        "path": "check-payment",
        "responseMode": "responseNode",
        "options": { "allowedOrigins": "*" }
      },
      "webhookId": "check-payment-webhook"
    },
    {
      "id": "cp-02-set-config",
      "name": "Set - Extract Query + Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300],
      "parameters": {
        "mode": "manual",
        "fields": {
          "values": [
            { "name": "code",             "type": "string", "value": "={{ $json.query.code }}" },
            { "name": "LARK_APP_ID",      "type": "string", "value": "cli_a958af6c4bf89e18" },
            { "name": "LARK_APP_SECRET",  "type": "string", "value": "rYvaoByzErm0qkI5xD2DQeJF2NvwwTey" },
            { "name": "LARK_APP_TOKEN",   "type": "string", "value": "ZpfMbtPOLaRWS9srU3EjOj7kpxd" },
            { "name": "LARK_TABLE_ID",    "type": "string", "value": "tblmJbEkZ6518VhN" }
          ]
        }
      }
    },
    {
      "id": "cp-03-get-token",
      "name": "Get Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "parameters": {
        "method": "POST",
        "url": "https://open.larksuite.com/open-apis/auth/v3/tenant_access_token/internal",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\"app_id\":\"{{ $json.LARK_APP_ID }}\",\"app_secret\":\"{{ $json.LARK_APP_SECRET }}\"}"
      }
    },
    {
      "id": "cp-04-set-token",
      "name": "Set - With Token",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [900, 300],
      "parameters": {
        "mode": "manual",
        "fields": {
          "values": [
            { "name": "larkToken",      "type": "string", "value": "={{ $json.tenant_access_token }}" },
            { "name": "code",           "type": "string", "value": "={{ $('Set - Extract Query + Config').item.json.code }}" },
            { "name": "LARK_APP_TOKEN", "type": "string", "value": "={{ $('Set - Extract Query + Config').item.json.LARK_APP_TOKEN }}" },
            { "name": "LARK_TABLE_ID",  "type": "string", "value": "={{ $('Set - Extract Query + Config').item.json.LARK_TABLE_ID }}" }
          ]
        }
      }
    },
    {
      "id": "cp-05-lark-search",
      "name": "Lark Base - Search by Payment Code",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 300],
      "parameters": {
        "method": "POST",
        "url": "=https://open.larksuite.com/open-apis/bitable/v1/apps/{{ $json.LARK_APP_TOKEN }}/tables/{{ $json.LARK_TABLE_ID }}/records/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Authorization", "value": "=Bearer {{ $json.larkToken }}" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"filter\": {\n    \"conjunction\": \"and\",\n    \"conditions\": [\n      { \"field_name\": \"Ma thanh toan\", \"operator\": \"is\", \"value\": [\"{{ $json.code }}\"] },\n      { \"field_name\": \"Trang thai\",    \"operator\": \"is\", \"value\": [\"Da thanh toan\"] }\n    ]\n  },\n  \"page_size\": 1\n}"
      }
    },
    {
      "id": "cp-06-if-paid",
      "name": "IF - Is Paid",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1340, 300],
      "parameters": {
        "conditions": {
          "options": { "typeValidation": "loose" },
          "conditions": [
            {
              "id": "cond-paid",
              "leftValue": "={{ $json.data.total }}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "gt" }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "cp-07-respond-paid",
      "name": "Respond - Paid",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1560, 160],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"paid\": true }",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Access-Control-Allow-Origin", "value": "*" },
              { "name": "Content-Type", "value": "application/json" }
            ]
          }
        }
      }
    },
    {
      "id": "cp-08-respond-pending",
      "name": "Respond - Pending",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1560, 440],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"paid\": false }",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Access-Control-Allow-Origin", "value": "*" },
              { "name": "Content-Type", "value": "application/json" }
            ]
          }
        }
      }
    }
  ],
  "connections": {
    "Webhook - Check Payment": {
      "main": [[{ "node": "Set - Extract Query + Config", "type": "main", "index": 0 }]]
    },
    "Set - Extract Query + Config": {
      "main": [[{ "node": "Get Token", "type": "main", "index": 0 }]]
    },
    "Get Token": {
      "main": [[{ "node": "Set - With Token", "type": "main", "index": 0 }]]
    },
    "Set - With Token": {
      "main": [[{ "node": "Lark Base - Search by Payment Code", "type": "main", "index": 0 }]]
    },
    "Lark Base - Search by Payment Code": {
      "main": [[{ "node": "IF - Is Paid", "type": "main", "index": 0 }]]
    },
    "IF - Is Paid": {
      "main": [
        [{ "node": "Respond - Paid",    "type": "main", "index": 0 }],
        [{ "node": "Respond - Pending", "type": "main", "index": 0 }]
      ]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "SePay" }, { "name": "Payment" }],
  "pinData": {}
}
